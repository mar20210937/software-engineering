@startuml use_case_diagram
left to right direction
title Use Case Diagram - Parking Management and Guidance System

actor "Driver/User" as User
actor Admin
actor "Sensor System" as Sensor
actor "Camera System" as Camera
actor "Payment Gateway" as Payment

rectangle "Parking Management and Guidance System" {
  usecase "View available\nparking spaces" as UC1
  usecase "Reserve parking\nspot" as UC2
  usecase "Receive route\nguidance" as UC3
  usecase "Pay parking\nfee" as UC4
  usecase "Detect vehicle\nentry/exit" as UC5
  usecase "Update parking\navailability" as UC6
  usecase "Manage parking\nspaces" as UC7
  usecase "Manage pricing\nand access policies" as UC8
  usecase "View occupancy\nstatus" as UC9
  usecase "Generate reports" as UC10
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

Sensor --> UC6
Camera --> UC5
Payment --> UC4

UC2 .> UC1 : <<include>>
UC3 .> UC2 : <<include>>

Admin --> UC7
Admin --> UC8
Admin --> UC9
Admin --> UC10

UC10 .> UC9 : <<include>>
UC8 .> UC7 : <<extend>>

@enduml
