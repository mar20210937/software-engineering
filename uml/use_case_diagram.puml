@startuml usecase
left to right direction
title Use Case Diagram - Parking Management and Guidance System

actor User
actor Admin

rectangle "Parking Management and Guidance System" {
  usecase "View available\nparking spaces" as UC1
  usecase "Reserve parking\nspot" as UC2
  usecase "Receive guidance\nto parking spot" as UC3
  usecase "Pay parking fee" as UC4
  usecase "View occupancy\nstatus" as UC5
  usecase "Manage parking\nspaces" as UC6
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

Admin --> UC5
Admin --> UC6

UC2 .> UC1 : <<include>>
UC3 .> UC2 : <<include>>
UC4 .> UC2 : <<extend>>

@enduml